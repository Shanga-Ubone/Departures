# Flask Configuration
FLASK_DEBUG=True
FLASK_PORT=5000

# Trafiklab GTFS Regional API keys (https://developer.trafiklab.se)
# Static and realtime are separate subscriptions/keys under "GTFS Regional".
# Used for real-time vehicle positions on the map and departure-board
# accuracy cross-checks. Optional — the app degrades gracefully without them.
TRAFIKLAB_STATIC_API_KEY=
TRAFIKLAB_REALTIME_API_KEY=

# Directory for the persisted static GTFS cache (~15MB). The static key is
# capped at 60 calls/30 days, so this MUST point at a Railway volume mount
# in production (e.g. /data) — otherwise every redeploy wipes it and burns
# another call. Defaults to the app directory, fine for local dev only.
TRAFIKLAB_CACHE_DIR=
